{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@bot/*": ["src/*"],
      "@commands": ["src/commands"],

      "@events/*": ["src/events"],

      "@handlers/*": ["src/handler/*"],
      "@utils": ["src/utils/"],
      
      "@types": ["src/types"],
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}